<resources>
    <!-- 深色主题 -->
    <style name="Theme.IPredict" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- 主要颜色 -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/primary_dark</item>

        <!-- 背景颜色 -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>

        <!-- 文本颜色 -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorOnBackground">@color/text_primary_dark</item>

        <!-- 组件样式 -->
        <item name="materialCardViewStyle">@style/CardView.Dark</item>
        <item name="bottomNavigationStyle">@style/BottomNavigation.Dark</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardView.Dark" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_gray</item>
    </style>

    <!-- 底部导航样式 -->
    <style name="BottomNavigation.Dark" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="backgroundColor">@color/dark_gray</item>
    </style>
</resources>