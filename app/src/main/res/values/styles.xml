<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 浮动按钮样式 -->
    <style name="FloatingActionButton.Light" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/white</item>
        <item name="tint">@color/black</item>
        <item name="rippleColor">@color/light_gray</item>
    </style>

    <style name="FloatingActionButton.Dark" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/dark_gray</item>
        <item name="tint">@color/white</item>
        <item name="rippleColor">@color/black</item>
    </style>

    <!-- 按钮样式 -->
    <style name="Button.Light" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="rippleColor">@color/light_gray</item>
    </style>

    <style name="Button.Dark" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/dark_gray</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/black</item>
    </style>

    <string name="event_types">事件列表</string>
    <string name="add_event_type">添加</string>
    <string name="edit_event_type">编辑</string>
    <string name="delete_event_type">删除</string>
    <string name="event_type_name">事件名称</string>
    <string name="choose_color">选择颜色</string>
    <string name="active">当前活动</string>

    <style name="NavigationViewStyle">
        <item name="android:listDivider">@android:color/transparent</item>
    </style>
</resources>